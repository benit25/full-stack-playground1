# ===== BACKEND =====
BACKEND_PORT=3011
DB_PROVIDER=sqlite
DATABASE_URL=sqlite:./plxyground.db
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:19006,http://localhost:3012

# Email (optional)
EMAIL_PROVIDER=stub
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-key

# Stub email logs to file/console in dev
LOCAL_STUB_EMAIL=true

# Media hosting (primary S3/Cloudinary; fallback to curated URLs in seeds)
MEDIA_PROVIDER=unsplash
# MEDIA_PROVIDER=s3
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Analytics & features
MOCK_ANALYTICS=false
MOCK_LIVE_ALERTS=false

# ===== FRONTEND =====
EXPO_PUBLIC_API_BASE_URL=http://localhost:3011

# ===== ADMIN PANEL =====
VITE_API_BASE_URL=http://localhost:3011
VITE_ADMIN_AUTO_REFRESH_INTERVAL=30000

