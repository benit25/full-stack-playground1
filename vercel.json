{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "{backend/node_modules/sql.js/dist/sql-wasm.wasm,admin-panel/dist/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/app",
      "destination": "/"
    },
    {
      "source": "/app/(.*)",
      "destination": "/"
    }
  ]
}
