#
# PLXYGROUND Environment (.env)
#
# Architecture (high level)
# - backend/ (Express API + DB): listens on PORT (default 3011)
# - frontend/ (React): normally served by Vite in dev, or by backend at /app in "single server" mode
# - admin-panel/ (React): normally served by Vite in dev, or by backend at /admin in "single server" mode
#
# Local dev (3 ports)
# - API:      http://localhost:3011
# - Frontend: http://localhost:19006
# - Admin:    http://localhost:3012
#
# Single-server mode (recommended fallback when Vite dev servers cannot run):
# - Start only the backend (PORT=3011)
# - Backend serves built UI:
#   - Frontend: http://localhost:3011/app/
#   - Admin:    http://localhost:3011/admin/
#
# Public server note (important)
# - If you expose the app publicly, do not hardcode API_BASE_URL=localhost in the built frontend.
# - Prefer same-origin API calls (baseURL="") when serving UI from the backend (PORT).
# - If hosting UI separately, build with a public API URL and set CORS_ORIGIN to the UI origin(s).
#

# =====================
# Backend (Express/API)
# =====================
# API listen port
PORT=3011

# Bind host:
# - 127.0.0.1 (recommended): local-only (usually avoids Windows Firewall prompts)
# - 0.0.0.0: expose on your LAN (will likely trigger a Windows Firewall prompt)
HOST=127.0.0.1

# DB_PROVIDER:
# - sqlite (default): uses sql.js and a local plxyground.db file
# - postgres: uses DATABASE_URL as a Postgres connection string
DB_PROVIDER=sqlite

# For sqlite, the current backend code uses a file at backend/plxyground.db (relative to backend/ process cwd).
# For postgres, set something like: postgres://user:pass@host:5432/dbname
DATABASE_URL=./plxyground.db

# JWT secret must be long and random in production.
JWT_SECRET=replace-with-a-long-random-secret

# Token TTL (examples: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# CORS_ORIGIN is a comma-separated allowlist of browser origins that may call the API.
# In local 3-port dev, include the Vite dev servers:
# - http://localhost:19006 (frontend)
# - http://localhost:3012  (admin)
# In single-server mode (UI served by backend), you can set CORS_ORIGIN to just the backend origin or leave defaults.
CORS_ORIGIN=http://localhost:19006,http://localhost:3012

# Email behavior (dev):
# - true: password reset endpoints include debug reset tokens in the JSON response
# - false: behaves like production (you need a real email provider to deliver reset links)
LOCAL_STUB_EMAIL=true

# Optional: password reset TTL (minutes)
PASSWORD_RESET_TTL_MINUTES=30

# ==========================
# Frontend/Admin API base URL
# ==========================
# These are read by the JS clients during development.
# Note: Vite reads env files from inside the project folder (frontend/.env, admin-panel/.env).
# The backend reads the repo-root .env by default (../.env).
#
# If you serve the built UI from the backend at /app and /admin, prefer SAME-ORIGIN:
# - set the frontend/admin base URL to empty string at build-time (baseURL="") so requests go to /api on the same host.
# If you host UI separately, set it to the public API URL (e.g., https://api.example.com).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3011
API_BASE_URL=http://localhost:3011

# =====================
# Optional mock toggles
# =====================
MOCK_ANALYTICS=false
MOCK_LIVE_ALERTS=false

# =========================
# Seed/demo credentials
# =========================
ADMIN_EMAIL=admin@plxyground.local
ADMIN_PASSWORD=Internet2026@
CREATOR_EMAIL=sarahjohnson@plxyground.local
CREATOR_PASSWORD=Password1!
BUSINESS_EMAIL=nike@plxyground.local
BUSINESS_PASSWORD=Password1!
