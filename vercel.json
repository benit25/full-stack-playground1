{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "backend/node_modules/sql.js/dist/sql-wasm.wasm",
        "frontend/dist/**",
        "admin-panel/dist/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
